# CONFIGURAÇÕES GERAIS DO SERVIDOR
PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL="https://whatsapp-bot-track-v2.onrender.com"
APP_BASE_URL="https://whatsapp-bot-track-v2.onrender.com"

# CREDENCIAIS DE LOGIN DO PAINEL (PROTEÇÃO EXCLUSIVA)
# Usuário e senha padrão caso não sejam definidos: Usuário: igorfernandes / Senha: 12345678
DASHBOARD_USERNAME="igorfernandes"
DASHBOARD_PASSWORD="12345678"

# PERSISTÊNCIA E DIRETÓRIOS DE DADOS (ALTAMENTE RECOMENDADO EM AMBIENTE DE PROD COM DISCO ACOPLADO)
# Defina caminhos permanentes (ex: no diretório /data montado como volume) para evitar perder o banco de dados e a sessão do WhatsApp.
DATABASE_PATH="/data/tracktool.db"
WHATSAPP_SESSION_PATH="/data/whatsapp_session"

# CHAVES DE APIS (OPCIONAIS OU SOB DEMANDA)
GEMINI_API_KEY="sua_chave_gemini_se_aplicar"
